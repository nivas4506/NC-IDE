<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme (VS Code Default Light+) -->
    <SolidColorBrush x:Key="TitleBarBackground" Color="#DDDDDD"/>
    <SolidColorBrush x:Key="ActivityBarBackground" Color="#2C2C2C"/> <!-- Often dark even in light mode, or #EAEAEA -->
    <SolidColorBrush x:Key="SidebarBackground" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="EditorBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TerminalBackground" Color="#FFFFFF"/>
    
    <SolidColorBrush x:Key="TabHeaderBackground" Color="#ECECEC"/>
    <SolidColorBrush x:Key="TabHeaderActiveBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabHeaderBorder" Color="#CCCCCC"/>
    
    <SolidColorBrush x:Key="PrimaryText" Color="#333333"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#616161"/>
    <SolidColorBrush x:Key="MutedText" Color="#858585"/>
    <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
    
    <SolidColorBrush x:Key="BorderColor" Color="#CCCCCC"/>
    
    <SolidColorBrush x:Key="HoverBackground" Color="#E5E5E5"/>
    
    <SolidColorBrush x:Key="WindowBackground" Color="#F3F3F3"/>
</ResourceDictionary>
