<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme (VS Code Default Dark+) -->
    <SolidColorBrush x:Key="TitleBarBackground" Color="#181818"/>
    <SolidColorBrush x:Key="ActivityBarBackground" Color="#181818"/>
    <SolidColorBrush x:Key="SidebarBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="EditorBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TerminalBackground" Color="#1E1E1E"/>
    
    <SolidColorBrush x:Key="TabHeaderBackground" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TabHeaderActiveBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TabHeaderBorder" Color="#181818"/>
    
    <SolidColorBrush x:Key="PrimaryText" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryText" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="MutedText" Color="#858585"/>
    <SolidColorBrush x:Key="AccentColor" Color="#007ACC"/>
    
    <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
    
    <SolidColorBrush x:Key="HoverBackground" Color="#2D2D2D"/>
    
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
</ResourceDictionary>
